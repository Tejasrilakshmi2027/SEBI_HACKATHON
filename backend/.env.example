# Application
APP_NAME=SEBI Sentinel AI
APP_VERSION=1.0.0
DEBUG=True

# Security
SECRET_KEY=your-secret-key-change-in-production-use-strong-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database - PostgreSQL
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sebi_user
POSTGRES_PASSWORD=sebi_password
POSTGRES_DB=sebi_sentinel

# Database - MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=sebi_sentinel_mongo

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# File Upload
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=uploads

# AI Models
MODEL_DIR=ai_models
DEVICE=cpu

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@sebisentinel.com
